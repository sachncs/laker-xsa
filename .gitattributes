# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python
*.pyi text diff=python

# Documentation
*.md text diff=markdown
*.rst text
*.txt text

# Configuration
*.toml text
*.yml text
*.yaml text
*.json text
*.cfg text
*.ini text

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Docker
Dockerfile text

# Git
.gitignore text
.gitattributes text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
